# ─────────────────────────────────────────────────────────────
# AutoAnalyst — Frontend environment variables
# Copy this file to `.env.local` and adjust if needed:
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# Base URL of the FastAPI backend (used by the Next.js API proxy routes)
NEXT_PUBLIC_FASTAPI_BACKEND_URL=http://0.0.0.0:8000

# Base URL the browser uses to open the SSE stream directly
NEXT_PUBLIC_API_URL=http://localhost:8000

# Legacy alias referenced in some docs
UPSTREAM_URL=http://0.0.0.0:8000
