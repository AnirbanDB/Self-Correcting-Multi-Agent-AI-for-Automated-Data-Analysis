# ─────────────────────────────────────────────────────────────
# AutoAnalyst — Backend environment variables
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────

# --- Runtime ---
ENV=local                     # local | dev | prod
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- LLM provider keys (set the one you use) ---
# OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# Google Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
# xAI Grok (optional):
XAI_API_KEY=

# Default model used by the agents (must be a valid model id)
OPENAI_MODEL=gpt-4o-mini

# --- Security ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# --- Database (matches docker/docker-compose.yml defaults) ---
WRITER_DB_URL=mysql+aiomysql://fastapi:fastapi@localhost:3306/fastapi
READER_DB_URL=mysql+aiomysql://fastapi:fastapi@localhost:3306/fastapi

# --- Redis cache ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Celery (task queue) ---
CELERY_BROKER_URL=amqp://user:bitnami@localhost:5672/
CELERY_BACKEND_URL=redis://:password123@localhost:6379/0
